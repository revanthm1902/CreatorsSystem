# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── GitHub Webhook Viewer (super-admin only) ────────────────────────────────
# Set VITE_WEBHOOK_ENABLED=true to reveal the GitHub Webhooks tab in the sidebar.
# Only the user whose email matches VITE_WEBHOOK_ALLOWED_EMAIL will see it.
# Leave both blank / unset on any other developer's machine to hide the feature.
VITE_WEBHOOK_ENABLED=false
VITE_WEBHOOK_ALLOWED_EMAIL=

# Server-side only (Vercel function) — NEVER prefix these with VITE_
# WEBHOOK_SECRET is the GitHub webhook secret ("super_secret_password" in prod)
WEBHOOK_SECRET=
# Service-role key so the Vercel function can write to the github_webhooks table
SUPABASE_SERVICE_ROLE_KEY=
