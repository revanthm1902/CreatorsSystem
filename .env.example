# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── GitHub Webhook Viewer (super-admin only) ────────────────────────────────
# Set VITE_WEBHOOK_ENABLED=true to reveal the GitHub Webhooks tab in the sidebar.
# The tab is only visible to users whose email is frank@aryverse.com or whose
# display name contains "frank" (case-insensitive). No other env vars needed.
VITE_WEBHOOK_ENABLED=false

# ─── Supabase Edge Function secrets (set via CLI, not stored here) ───────────
# supabase secrets set WEBHOOK_SECRET=super_secret_password
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# The edge function is deployed with:
#   supabase functions deploy github-webhook --no-verify-jwt
